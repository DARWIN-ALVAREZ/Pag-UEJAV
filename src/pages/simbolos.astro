---
import PageLayout from "../layouts/PageLayout.astro";
import PageHeader from "../components/common/PageHeader.astro";
import Shield from "../components/symbols/Shield.astro";
import Anthem from "../components/symbols/Anthem.astro";
import PatronBio from "../components/symbols/PatronBio.astro";
---

<PageLayout
    title="Símbolos Institucionales"
    description="Escudo, himno y biografía del patrono de la Unidad Educativa José Acosta Vallejo. Conoce los símbolos que nos identifican desde 1925."
>
    <PageHeader
        title="Símbolos Institucionales"
        subtitle="Los elementos que representan nuestra identidad, tradición y compromiso con la educación."
        breadcrumb="Símbolos"
    />

    <Shield />
    <Anthem />
    <PatronBio />

    <!-- CTA final -->
    <section class="py-20 bg-primary-950 relative overflow-hidden">
        <div
            class="absolute inset-0"
            style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px;"
        >
        </div>
        <div
            class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-secondary-400/20 to-transparent"
        >
        </div>

        <div class="relative z-10 max-w-2xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold text-white tracking-tight">
                Conoce a nuestro equipo
            </h2>
            <p class="text-neutral-400 mt-4 leading-relaxed">
                Descubre al equipo directivo y docente que lleva adelante la
                misión educativa de nuestra institución.
            </p>
            <a
                href="/autoridades"
                class="inline-flex items-center gap-2 mt-8 text-sm font-medium text-secondary-400 hover:text-secondary-300 transition-colors uppercase tracking-wide group"
            >
                Ver autoridades y personal
                <span class="group-hover:translate-x-1 transition-transform"
                    >→</span
                >
            </a>
        </div>
    </section>
</PageLayout>
