---
import PageLayout from "../layouts/PageLayout.astro";
import PageHeader from "../components/common/PageHeader.astro";
import eventsData from "../data/events.json";

const tipoColors: Record<string, string> = {
    Académico: "bg-primary-800",
    Reunión: "bg-secondary-500",
    Evento: "bg-secondary-600",
    Deportes: "bg-emerald-600",
    Cultural: "bg-violet-600",
    Feriado: "bg-red-600",
};
---

<PageLayout
    title="Eventos"
    description="Calendario de eventos y actividades de la Unidad Educativa José Acosta Vallejo. Mantente informado de las fechas importantes."
>
    <PageHeader
        title="Calendario de Eventos"
        subtitle="Mantente al día con las actividades, reuniones y fechas importantes de nuestra institución."
        breadcrumb="Eventos"
    />

    <section class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Leyenda de colores -->
            <div class="flex flex-wrap items-center gap-4 mb-8 justify-center">
                {
                    Object.entries(tipoColors).map(([tipo, color]) => (
                        <div class="flex items-center gap-2">
                            <span class={`w-2.5 h-2.5 ${color} rounded-full`} />
                            <span class="text-xs text-neutral-500">{tipo}</span>
                        </div>
                    ))
                }
            </div>

            <!-- Navegación del mes -->
            <div
                class="flex items-center justify-between mb-6 border border-neutral-200 px-6 py-4"
            >
                <button
                    id="prev-month"
                    class="w-9 h-9 flex items-center justify-center bg-primary-950 text-white hover:bg-primary-800 transition-colors"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M15 19l-7-7 7-7"></path>
                    </svg>
                </button>
                <div class="text-center">
                    <h2
                        id="month-title"
                        class="text-xl font-bold text-primary-900 uppercase tracking-wide"
                    >
                    </h2>
                </div>
                <button
                    id="next-month"
                    class="w-9 h-9 flex items-center justify-center bg-primary-950 text-white hover:bg-primary-800 transition-colors"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M9 5l7 7-7 7"></path>
                    </svg>
                </button>
            </div>

            <!-- Días de la semana -->
            <div class="grid grid-cols-7 bg-primary-950">
                {
                    ["Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Dom"].map(
                        (dia) => (
                            <div class="py-3 text-center">
                                <span class="text-[10px] font-semibold uppercase tracking-widest text-white/70">
                                    {dia}
                                </span>
                            </div>
                        ),
                    )
                }
            </div>

            <!-- Cuadrícula del calendario -->
            <div
                id="calendar-grid"
                class="grid grid-cols-7 border-l border-b border-neutral-200"
            >
                <!-- Se llena con JavaScript -->
            </div>

            <!-- Detalle del evento seleccionado -->
            <div
                id="event-detail"
                class="hidden mt-8 border border-neutral-200"
            >
                <div
                    class="bg-primary-950 px-6 py-4 flex items-center justify-between"
                >
                    <h3
                        id="detail-title"
                        class="text-sm font-bold text-white uppercase tracking-wide"
                    >
                    </h3>
                    <button
                        id="close-detail"
                        class="text-white/50 hover:text-white transition-colors"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
                <div class="p-6">
                    <div class="flex flex-wrap items-center gap-4 mb-4">
                        <span
                            id="detail-tipo"
                            class="text-[10px] font-semibold uppercase tracking-widest text-white px-2.5 py-1"
                        ></span>
                        <span
                            id="detail-fecha"
                            class="text-sm font-bold text-primary-800"></span>
                        <span id="detail-hora" class="text-sm text-neutral-500"
                        ></span>
                    </div>
                    <p
                        id="detail-descripcion"
                        class="text-sm text-neutral-600 leading-relaxed"
                    >
                    </p>
                    <div
                        id="detail-lugar-wrap"
                        class="flex items-center gap-2 mt-4"
                    >
                        <svg
                            class="w-4 h-4 text-secondary-600"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path>
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <span id="detail-lugar" class="text-sm text-neutral-500"
                        ></span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Próximos Eventos (lista) -->
    <section class="py-20 bg-neutral-50">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-14">
                <h2
                    class="text-3xl md:text-4xl font-bold text-primary-900 tracking-tight"
                >
                    Próximos Eventos
                </h2>
                <p class="text-neutral-400 text-base mt-3">
                    Todos los eventos programados para este año lectivo
                </p>
                <div class="w-12 h-0.5 bg-secondary-500 mt-5 mx-auto"></div>
            </div>

            <div class="space-y-px border border-neutral-200">
                {
                    eventsData
                        .filter(
                            (e) =>
                                new Date(e.fecha + "T12:00:00") >= new Date(),
                        )
                        .slice(0, 5)
                        .map((evento, index) => (
                            <div
                                class:list={[
                                    "flex flex-col md:flex-row md:items-center gap-4 md:gap-8 p-6 group hover:bg-primary-50/50 transition-colors relative",
                                    index % 2 === 0
                                        ? "bg-white"
                                        : "bg-neutral-50/50",
                                ]}
                            >
                                <div class="absolute top-0 left-0 w-0 h-full border-l-2 border-transparent group-hover:border-secondary-500 transition-all duration-300" />

                                <div class="flex-shrink-0 md:w-20 text-left md:text-center">
                                    <span class="text-sm font-bold text-primary-800">
                                        {new Date(
                                            evento.fecha + "T12:00:00",
                                        ).toLocaleDateString("es-EC", {
                                            day: "numeric",
                                            month: "short",
                                        })}
                                    </span>
                                    <p class="text-[10px] font-semibold uppercase tracking-widest text-secondary-600 mt-0.5">
                                        {evento.tipo}
                                    </p>
                                </div>

                                <div class="hidden md:block w-px h-12 bg-neutral-200" />

                                <div class="flex-1">
                                    <h3 class="text-sm font-bold text-primary-900 uppercase tracking-wide">
                                        {evento.titulo}
                                    </h3>
                                    <p class="text-sm text-neutral-500 mt-1.5 leading-relaxed">
                                        {evento.descripcion}
                                    </p>
                                </div>

                                {evento.hora && (
                                    <div class="flex-shrink-0 text-right hidden md:block">
                                        <span class="text-xs text-neutral-400">
                                            {evento.hora}
                                        </span>
                                        {evento.lugar && (
                                            <p class="text-xs text-neutral-400">
                                                {evento.lugar}
                                            </p>
                                        )}
                                    </div>
                                )}
                            </div>
                        ))
                }
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-primary-950 relative overflow-hidden">
        <div
            class="absolute inset-0"
            style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px;"
        >
        </div>
        <div
            class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-secondary-400/20 to-transparent"
        >
        </div>
        <div class="relative z-10 max-w-2xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold text-white tracking-tight">
                ¿Quieres estar al día?
            </h2>
            <p class="text-neutral-400 mt-4 leading-relaxed">
                Visítanos o contáctanos para más información sobre nuestras
                actividades y eventos.
            </p>
            <a
                href="/contacto"
                class="inline-flex items-center gap-2 mt-8 text-sm font-medium text-secondary-400 hover:text-secondary-300 transition-colors uppercase tracking-wide group"
            >
                Contáctanos
                <span class="group-hover:translate-x-1 transition-transform"
                    >→</span
                >
            </a>
        </div>
    </section>
</PageLayout>

<script define:vars={{ eventsData, tipoColors }}>
    const months = [
        "Enero",
        "Febrero",
        "Marzo",
        "Abril",
        "Mayo",
        "Junio",
        "Julio",
        "Agosto",
        "Septiembre",
        "Octubre",
        "Noviembre",
        "Diciembre",
    ];

    let currentDate = new Date(2026, 2, 1); // Marzo 2026

    const grid = document.getElementById("calendar-grid");
    const title = document.getElementById("month-title");
    const detail = document.getElementById("event-detail");
    const prevBtn = document.getElementById("prev-month");
    const nextBtn = document.getElementById("next-month");
    const closeBtn = document.getElementById("close-detail");

    function getEventsForDate(year, month, day) {
        const dateStr = `${year}-${String(month + 1).padStart(2, "0")}-${String(day).padStart(2, "0")}`;
        return eventsData.filter((e) => e.fecha === dateStr);
    }

    function showDetail(event) {
        const fecha = new Date(event.fecha + "T12:00:00");
        document.getElementById("detail-title").textContent = event.titulo;
        document.getElementById("detail-tipo").textContent = event.tipo;
        document.getElementById("detail-tipo").className =
            `text-[10px] font-semibold uppercase tracking-widest text-white px-2.5 py-1 ${tipoColors[event.tipo] || "bg-neutral-500"}`;
        document.getElementById("detail-fecha").textContent =
            fecha.toLocaleDateString("es-EC", {
                weekday: "long",
                day: "numeric",
                month: "long",
                year: "numeric",
            });
        document.getElementById("detail-hora").textContent = event.hora
            ? event.hora
            : "";
        document.getElementById("detail-descripcion").textContent =
            event.descripcion;
        document.getElementById("detail-lugar").textContent = event.lugar || "";
        document.getElementById("detail-lugar-wrap").style.display = event.lugar
            ? "flex"
            : "none";
        detail.classList.remove("hidden");
        detail.scrollIntoView({ behavior: "smooth", block: "nearest" });
    }

    function renderCalendar() {
        const year = currentDate.getFullYear();
        const month = currentDate.getMonth();

        title.textContent = `${months[month]} ${year}`;

        const firstDay = new Date(year, month, 1).getDay();
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const startOffset = firstDay === 0 ? 6 : firstDay - 1;

        const today = new Date();
        const isCurrentMonth =
            today.getFullYear() === year && today.getMonth() === month;

        let html = "";

        // Días vacíos antes del primer día
        for (let i = 0; i < startOffset; i++) {
            html += `<div class="min-h-[80px] md:min-h-[100px] border-t border-r border-neutral-200 bg-neutral-50/30"></div>`;
        }

        // Días del mes
        for (let day = 1; day <= daysInMonth; day++) {
            const events = getEventsForDate(year, month, day);
            const isToday = isCurrentMonth && today.getDate() === day;

            html += `<div class="min-h-[80px] md:min-h-[100px] border-t border-r border-neutral-200 p-1.5 md:p-2 relative ${isToday ? "bg-primary-50/50" : "bg-white"} hover:bg-primary-50/30 transition-colors cursor-pointer" data-day="${day}">`;

            // Número del día
            html += `<span class="text-xs font-semibold ${isToday ? "bg-primary-900 text-white w-6 h-6 flex items-center justify-center" : "text-neutral-600"}">${day}</span>`;

            // Eventos del día
            if (events.length > 0) {
                events.forEach((evt, i) => {
                    if (i < 2) {
                        const color = tipoColors[evt.tipo] || "bg-neutral-500";
                        html += `<div class="mt-1 hidden md:block" data-event-index="${eventsData.indexOf(evt)}">
              <div class="${color} px-1.5 py-0.5 cursor-pointer hover:opacity-80 transition-opacity">
                <span class="text-[9px] text-white font-medium leading-tight line-clamp-1">${evt.titulo}</span>
              </div>
            </div>`;
                    }
                });
                if (events.length > 2) {
                    html += `<span class="text-[9px] text-secondary-600 font-semibold mt-0.5 hidden md:block">+${events.length - 2} más</span>`;
                }
                // Mobile: solo punto indicador
                html += `<div class="md:hidden flex gap-0.5 mt-1">`;
                events.forEach((evt) => {
                    const color = tipoColors[evt.tipo] || "bg-neutral-500";
                    html += `<span class="w-1.5 h-1.5 ${color} rounded-full"></span>`;
                });
                html += `</div>`;
            }

            html += `</div>`;
        }

        // Días vacíos al final para completar la grilla
        const totalCells = startOffset + daysInMonth;
        const remainder = totalCells % 7;
        if (remainder > 0) {
            for (let i = 0; i < 7 - remainder; i++) {
                html += `<div class="min-h-[80px] md:min-h-[100px] border-t border-r border-neutral-200 bg-neutral-50/30"></div>`;
            }
        }

        grid.innerHTML = html;

        // Click en día
        grid.querySelectorAll("[data-day]").forEach((cell) => {
            cell.addEventListener("click", () => {
                const day = parseInt(cell.getAttribute("data-day"));
                const events = getEventsForDate(year, month, day);
                if (events.length > 0) {
                    showDetail(events[0]);
                }
            });
        });

        // Click en evento específico
        grid.querySelectorAll("[data-event-index]").forEach((el) => {
            el.addEventListener("click", (e) => {
                e.stopPropagation();
                const idx = parseInt(el.getAttribute("data-event-index"));
                showDetail(eventsData[idx]);
            });
        });
    }

    prevBtn.addEventListener("click", () => {
        currentDate.setMonth(currentDate.getMonth() - 1);
        renderCalendar();
        detail.classList.add("hidden");
    });

    nextBtn.addEventListener("click", () => {
        currentDate.setMonth(currentDate.getMonth() + 1);
        renderCalendar();
        detail.classList.add("hidden");
    });

    closeBtn.addEventListener("click", () => {
        detail.classList.add("hidden");
    });

    renderCalendar();
</script>
