---
import PageLayout from "../layouts/PageLayout.astro";
import PageHeader from "../components/common/PageHeader.astro";
import SectionTitle from "../components/common/SectionTitle.astro";
import { getHonorData } from "../services/googleSheets";

const honorData = await getHonorData();
---

<PageLayout
    title="Cuadro de Honor"
    description="Reconocimiento a los mejores estudiantes de la U.E. Jose Acosta Vallejo."
>
    <PageHeader
        title="Cuadro de Honor"
        subtitle="Reconocemos el esfuerzo, la dedicacion y la excelencia academica de nuestros estudiantes destacados."
        breadcrumb="Cuadro de Honor"
    />

    <!-- Periodo -->
    <section class="py-12 bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <div
                class="inline-flex items-center gap-3 border border-neutral-200 px-6 py-3"
            >
                <span
                    class="text-[10px] font-semibold uppercase tracking-[0.2em] text-neutral-400"
                    >Periodo</span
                >
                <span class="w-px h-4 bg-neutral-200"></span>
                <span class="text-sm font-bold text-primary-900"
                    >{honorData.anioLectivo}</span
                >
            </div>
        </div>
    </section>

    <!-- Podio -->
    <section class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <SectionTitle
                title="Excelencia Academica"
                subtitle="Los tres mejores promedios generales de toda la institucion"
            />

            <!-- Desktop Podio -->
            <div class="hidden md:grid md:grid-cols-3 gap-6 items-end">
                <!-- 2do lugar - izquierda -->
                {
                    honorData.podio
                        .filter((p) => p.posicion === 2)
                        .map((puesto) => (
                            <div class="border border-neutral-200 bg-white min-h-[280px] flex flex-col">
                                <div class="bg-primary-800 px-5 py-3 flex items-center justify-between">
                                    <span class="text-xs font-bold uppercase tracking-widest text-white/70">
                                        Segundo Lugar
                                    </span>
                                    <span class="text-sm font-bold text-secondary-300">
                                        {puesto.estudiantes[0].promedio.toFixed(
                                            2,
                                        )}
                                    </span>
                                </div>
                                {puesto.estudiantes.map((est, i) => (
                                    <div
                                        class:list={[
                                            "p-5",
                                            i > 0 &&
                                                "border-t border-neutral-100",
                                        ]}
                                    >
                                        {puesto.estudiantes.length > 1 &&
                                            i === 0 && (
                                                <span class="text-[9px] font-semibold uppercase tracking-widest text-secondary-600 block mb-3">
                                                    Empate
                                                </span>
                                            )}
                                        <div class="flex items-center gap-3 mb-2">
                                            <div class="w-9 h-9 bg-primary-900 flex items-center justify-center flex-shrink-0">
                                                <span class="text-white text-[10px] font-bold">
                                                    {est.nombre
                                                        .split(" ")
                                                        .map(
                                                            (n: string) => n[0],
                                                        )
                                                        .slice(0, 2)
                                                        .join("")}
                                                </span>
                                            </div>
                                            <div>
                                                <p class="text-sm font-bold text-primary-900 leading-tight">
                                                    {est.nombre}
                                                </p>
                                                <p class="text-[11px] text-neutral-500">
                                                    {est.grado} — Paralelo{" "}
                                                    {est.paralelo}
                                                </p>
                                            </div>
                                        </div>
                                        <div class="ml-12">
                                            <span class="text-[9px] font-semibold uppercase tracking-widest text-neutral-400">
                                                Docente
                                            </span>
                                            <p class="text-xs text-neutral-500">
                                                {est.docente}
                                            </p>
                                        </div>
                                    </div>
                                ))}
                                <div class="h-2 bg-primary-800 mt-auto" />
                            </div>
                        ))
                }

                <!-- 1er lugar - centro, mas alto -->
                {
                    honorData.podio
                        .filter((p) => p.posicion === 1)
                        .map((puesto) => (
                            <div class="border-2 border-primary-900 bg-primary-950 relative min-h-[350px] flex flex-col">
                                <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-secondary-500 px-4 py-1">
                                    <span class="text-[10px] font-bold uppercase tracking-widest text-white">
                                        N.1
                                    </span>
                                </div>
                                <div class="px-6 pt-8 pb-3 text-center border-b border-white/10">
                                    <span class="text-[10px] font-semibold uppercase tracking-[0.2em] text-secondary-400 block mb-1">
                                        Primer Lugar
                                    </span>
                                    <span class="text-2xl font-bold text-white">
                                        {puesto.estudiantes[0].promedio.toFixed(
                                            2,
                                        )}
                                    </span>
                                </div>
                                {puesto.estudiantes.map((est, i) => (
                                    <div
                                        class:list={[
                                            "p-6",
                                            i > 0 && "border-t border-white/10",
                                        ]}
                                    >
                                        {puesto.estudiantes.length > 1 &&
                                            i === 0 && (
                                                <span class="text-[9px] font-semibold uppercase tracking-widest text-secondary-400 block mb-3">
                                                    Empate
                                                </span>
                                            )}
                                        <div class="flex items-center gap-3 mb-3">
                                            <div class="w-10 h-10 bg-secondary-500 flex items-center justify-center flex-shrink-0">
                                                <span class="text-white text-xs font-bold">
                                                    {est.nombre
                                                        .split(" ")
                                                        .map(
                                                            (n: string) => n[0],
                                                        )
                                                        .slice(0, 2)
                                                        .join("")}
                                                </span>
                                            </div>
                                            <div>
                                                <p class="text-sm font-bold text-white leading-tight">
                                                    {est.nombre}
                                                </p>
                                                <p class="text-[11px] text-neutral-400">
                                                    {est.grado} — Paralelo{" "}
                                                    {est.paralelo}
                                                </p>
                                            </div>
                                        </div>
                                        <div class="ml-13">
                                            <span class="text-[9px] font-semibold uppercase tracking-widest text-neutral-500">
                                                Docente
                                            </span>
                                            <p class="text-xs text-neutral-400">
                                                {est.docente}
                                            </p>
                                        </div>
                                    </div>
                                ))}
                                <div class="h-3 bg-secondary-500 mt-auto" />
                            </div>
                        ))
                }

                <!-- 3er lugar - derecha -->
                {
                    honorData.podio
                        .filter((p) => p.posicion === 3)
                        .map((puesto) => (
                            <div class="border border-neutral-200 bg-white min-h-[280px] flex flex-col">
                                <div class="bg-primary-700 px-5 py-3 flex items-center justify-between">
                                    <span class="text-xs font-bold uppercase tracking-widest text-white/70">
                                        Tercer Lugar
                                    </span>
                                    <span class="text-sm font-bold text-secondary-300">
                                        {puesto.estudiantes[0].promedio.toFixed(
                                            2,
                                        )}
                                    </span>
                                </div>
                                {puesto.estudiantes.map((est, i) => (
                                    <div
                                        class:list={[
                                            "p-5",
                                            i > 0 &&
                                                "border-t border-neutral-100",
                                        ]}
                                    >
                                        {puesto.estudiantes.length > 1 &&
                                            i === 0 && (
                                                <span class="text-[9px] font-semibold uppercase tracking-widest text-secondary-600 block mb-3">
                                                    Empate
                                                </span>
                                            )}
                                        <div class="flex items-center gap-3 mb-2">
                                            <div class="w-9 h-9 bg-primary-900 flex items-center justify-center flex-shrink-0">
                                                <span class="text-white text-[10px] font-bold">
                                                    {est.nombre
                                                        .split(" ")
                                                        .map(
                                                            (n: string) => n[0],
                                                        )
                                                        .slice(0, 2)
                                                        .join("")}
                                                </span>
                                            </div>
                                            <div>
                                                <p class="text-sm font-bold text-primary-900 leading-tight">
                                                    {est.nombre}
                                                </p>
                                                <p class="text-[11px] text-neutral-500">
                                                    {est.grado} — Paralelo{" "}
                                                    {est.paralelo}
                                                </p>
                                            </div>
                                        </div>
                                        <div class="ml-12">
                                            <span class="text-[9px] font-semibold uppercase tracking-widest text-neutral-400">
                                                Docente
                                            </span>
                                            <p class="text-xs text-neutral-500">
                                                {est.docente}
                                            </p>
                                        </div>
                                    </div>
                                ))}
                                <div class="h-2 bg-primary-700 mt-auto" />
                            </div>
                        ))
                }
            </div>

            <!-- Mobile: Cards verticales -->
            <div class="md:hidden space-y-4">
                {
                    honorData.podio.map((puesto) => {
                        const isFirst = puesto.posicion === 1;
                        const labels = {
                            1: "Primer Lugar",
                            2: "Segundo Lugar",
                            3: "Tercer Lugar",
                        };
                        const label =
                            labels[puesto.posicion as keyof typeof labels];
                        return (
                            <div
                                class:list={[
                                    "border",
                                    isFirst
                                        ? "border-primary-900 bg-primary-950"
                                        : "border-neutral-200 bg-white",
                                ]}
                            >
                                <div
                                    class:list={[
                                        "px-5 py-3 flex items-center justify-between",
                                        isFirst
                                            ? "border-b border-white/10"
                                            : "border-b border-neutral-100 bg-primary-800",
                                    ]}
                                >
                                    {isFirst && (
                                        <span class="text-[10px] font-bold uppercase tracking-widest text-secondary-400">
                                            {label}
                                        </span>
                                    )}
                                    {!isFirst && (
                                        <span class="text-xs font-bold uppercase tracking-widest text-white/70">
                                            {label}
                                        </span>
                                    )}
                                    <div class="flex items-center gap-2">
                                        {puesto.estudiantes.length > 1 && (
                                            <span
                                                class:list={[
                                                    "text-[9px] font-semibold uppercase tracking-widest",
                                                    isFirst
                                                        ? "text-neutral-500"
                                                        : "text-white/50",
                                                ]}
                                            >
                                                Empate
                                            </span>
                                        )}
                                        <span
                                            class:list={[
                                                "text-sm font-bold",
                                                isFirst
                                                    ? "text-white"
                                                    : "text-secondary-300",
                                            ]}
                                        >
                                            {puesto.estudiantes[0].promedio.toFixed(
                                                2,
                                            )}
                                        </span>
                                    </div>
                                </div>
                                {puesto.estudiantes.map((est, i) => (
                                    <div
                                        class:list={[
                                            "p-5",
                                            i > 0 &&
                                                (isFirst
                                                    ? "border-t border-white/10"
                                                    : "border-t border-neutral-100"),
                                        ]}
                                    >
                                        <div class="flex items-center gap-3 mb-2">
                                            <div
                                                class:list={[
                                                    "w-9 h-9 flex items-center justify-center flex-shrink-0",
                                                    isFirst
                                                        ? "bg-secondary-500"
                                                        : "bg-primary-900",
                                                ]}
                                            >
                                                <span class="text-white text-[10px] font-bold">
                                                    {est.nombre
                                                        .split(" ")
                                                        .map(
                                                            (n: string) => n[0],
                                                        )
                                                        .slice(0, 2)
                                                        .join("")}
                                                </span>
                                            </div>
                                            <div>
                                                <p
                                                    class:list={[
                                                        "text-sm font-bold leading-tight",
                                                        isFirst
                                                            ? "text-white"
                                                            : "text-primary-900",
                                                    ]}
                                                >
                                                    {est.nombre}
                                                </p>
                                                <p
                                                    class:list={[
                                                        "text-[11px]",
                                                        isFirst
                                                            ? "text-neutral-400"
                                                            : "text-neutral-500",
                                                    ]}
                                                >
                                                    {est.grado} — Paralelo{" "}
                                                    {est.paralelo}
                                                </p>
                                            </div>
                                        </div>
                                        <div class="ml-12">
                                            <span
                                                class:list={[
                                                    "text-[9px] font-semibold uppercase tracking-widest",
                                                    isFirst
                                                        ? "text-neutral-500"
                                                        : "text-neutral-400",
                                                ]}
                                            >
                                                Docente
                                            </span>
                                            <p
                                                class:list={[
                                                    "text-xs",
                                                    isFirst
                                                        ? "text-neutral-400"
                                                        : "text-neutral-500",
                                                ]}
                                            >
                                                {est.docente}
                                            </p>
                                        </div>
                                    </div>
                                ))}
                                {isFirst && (
                                    <div class="h-2 bg-secondary-500" />
                                )}
                                {!isFirst && (
                                    <div class="h-1.5 bg-primary-700" />
                                )}
                            </div>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <!-- Mejor por Grado -->
    <section class="py-20 bg-neutral-50">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <SectionTitle
                title="Mejor Estudiante por Grado"
                subtitle="El estudiante con el mejor promedio de cada grado"
            />
            <div class="border border-neutral-200">
                <div
                    class="grid grid-cols-[1fr_100px_70px_70px] bg-primary-950 text-white"
                >
                    <div class="px-6 py-3">
                        <span
                            class="text-[10px] font-semibold uppercase tracking-widest"
                            >Estudiante</span
                        >
                    </div>
                    <div class="px-4 py-3">
                        <span
                            class="text-[10px] font-semibold uppercase tracking-widest"
                            >Grado</span
                        >
                    </div>
                    <div class="px-4 py-3 text-center">
                        <span
                            class="text-[10px] font-semibold uppercase tracking-widest"
                            >Paralelo</span
                        >
                    </div>
                    <div class="px-4 py-3 text-center">
                        <span
                            class="text-[10px] font-semibold uppercase tracking-widest"
                            >Prom.</span
                        >
                    </div>
                </div>
                {
                    honorData.mejorPorGrado.map((est, index) => (
                        <div
                            class:list={[
                                "grid grid-cols-[1fr_100px_70px_70px] group hover:bg-primary-50/50 transition-colors",
                                index % 2 === 0
                                    ? "bg-white"
                                    : "bg-neutral-50/50",
                                index > 0 && "border-t border-neutral-100",
                            ]}
                        >
                            <div class="px-6 py-4 flex items-center gap-3">
                                <div class="w-7 h-7 bg-primary-900 flex items-center justify-center flex-shrink-0">
                                    <span class="text-white text-[9px] font-bold">
                                        {est.nombre
                                            .split(" ")
                                            .map((n: string) => n[0])
                                            .slice(0, 2)
                                            .join("")}
                                    </span>
                                </div>
                                <span class="text-sm font-semibold text-primary-900">
                                    {est.nombre}
                                </span>
                            </div>
                            <div class="px-4 py-4 flex items-center">
                                <span class="text-sm text-neutral-600">
                                    {est.grado}
                                </span>
                            </div>
                            <div class="px-4 py-4 flex items-center justify-center">
                                <span class="text-xs font-semibold text-secondary-600 bg-secondary-50 px-2.5 py-0.5">
                                    {est.paralelo}
                                </span>
                            </div>
                            <div class="px-4 py-4 flex items-center justify-center">
                                <span class="text-sm font-bold text-primary-800">
                                    {est.promedio.toFixed(2)}
                                </span>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-primary-950 relative overflow-hidden">
        <div
            class="absolute inset-0"
            style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px;"
        >
        </div>
        <div
            class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-secondary-400/20 to-transparent"
        >
        </div>
        <div class="relative z-10 max-w-2xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold text-white tracking-tight">
                La excelencia se construye cada dia
            </h2>
            <p class="text-neutral-400 mt-4 leading-relaxed">
                Felicitamos a nuestros estudiantes destacados y los motivamos a
                seguir dando lo mejor.
            </p>
            <a
                href="/"
                class="inline-flex items-center gap-2 mt-8 text-sm font-medium text-secondary-400 hover:text-secondary-300 transition-colors uppercase tracking-wide group"
            >
                Volver al inicio
                <span class="group-hover:translate-x-1 transition-transform"
                    >-></span
                >
            </a>
        </div>
    </section>
</PageLayout>
