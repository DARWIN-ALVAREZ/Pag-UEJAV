---
import PageLayout from "../../layouts/PageLayout.astro";
import blogData from "../../data/blog.json";

export function getStaticPaths() {
    return blogData.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;

const fechaFormateada = new Date(post.fecha + "T12:00:00").toLocaleDateString(
    "es-EC",
    {
        weekday: "long",
        day: "numeric",
        month: "long",
        year: "numeric",
    },
);

// Obtener posts relacionados (misma categoría, excluyendo el actual)
const relacionados = blogData
    .filter((p) => p.categoria === post.categoria && p.slug !== post.slug)
    .slice(0, 2);

const parrafos = post.contenido.split("\n\n");
---

<PageLayout title={post.titulo} description={post.resumen}>
    <!-- Breadcrumb -->
    <div class="bg-neutral-50 border-b border-neutral-200">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <nav class="flex items-center gap-2 text-xs text-neutral-400">
                <a href="/" class="hover:text-primary-600 transition-colors"
                    >Inicio</a
                >
                <span>→</span>
                <a
                    href="/noticias"
                    class="hover:text-primary-600 transition-colors">Noticias</a
                >
                <span>→</span>
                <span class="text-neutral-600 truncate">{post.titulo}</span>
            </nav>
        </div>
    </div>

    <article class="py-16 bg-white">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
            <!-- Header del artículo -->
            <header class="mb-12">
                <div class="flex items-center gap-3 mb-5">
                    <span
                        class="text-[10px] font-semibold uppercase tracking-widest text-secondary-600 bg-secondary-50 px-2.5 py-1"
                        >{post.categoria}</span
                    >
                    <span class="text-[11px] text-neutral-400"
                        >{fechaFormateada}</span
                    >
                </div>

                <h1
                    class="text-3xl md:text-4xl font-bold text-primary-900 tracking-tight leading-tight"
                >
                    {post.titulo}
                </h1>

                <p class="text-lg text-neutral-500 mt-5 leading-relaxed">
                    {post.resumen}
                </p>

                <div
                    class="flex items-center gap-3 mt-6 pt-6 border-t border-neutral-100"
                >
                    <div
                        class="w-8 h-8 bg-primary-900 flex items-center justify-center"
                    >
                        <span class="text-white text-[10px] font-bold">UE</span>
                    </div>
                    <div>
                        <p class="text-xs font-semibold text-primary-900">
                            {post.autor}
                        </p>
                        <p class="text-[11px] text-neutral-400">
                            U.E. José Acosta Vallejo
                        </p>
                    </div>
                </div>
            </header>

            <!-- Imagen principal -->
            <div
                class="aspect-[16/9] bg-gradient-to-br from-primary-900 to-primary-800 flex items-center justify-center relative overflow-hidden mb-12 border border-neutral-200"
            >
                <div
                    class="absolute inset-0"
                    style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 30px 30px;"
                >
                </div>
                <div class="relative text-center">
                    <span class="text-white/20">
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="48"
                            height="48"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="1.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <rect
                                width="18"
                                height="18"
                                x="3"
                                y="3"
                                rx="2"
                                ry="2"></rect>
                            <circle cx="9" cy="9" r="2"></circle>
                            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"
                            ></path>
                        </svg>
                    </span>
                    <p
                        class="text-[10px] text-white/20 uppercase tracking-widest mt-2"
                    >
                        Imagen próximamente
                    </p>
                </div>
            </div>

            <!-- Contenido -->
            <div class="prose-custom">
                {
                    parrafos.map((parrafo) => (
                        <p class="text-neutral-600 leading-relaxed mb-5 text-[15px]">
                            {parrafo}
                        </p>
                    ))
                }
            </div>

            <!-- Compartir / Volver -->
            <div
                class="mt-12 pt-8 border-t border-neutral-200 flex items-center justify-between"
            >
                <a
                    href="/noticias"
                    class="inline-flex items-center gap-2 text-sm font-medium text-primary-700 hover:text-secondary-600 transition-colors group"
                >
                    <span
                        class="group-hover:-translate-x-1 transition-transform"
                        >←</span
                    >
                    Volver a noticias
                </a>
                <span
                    class="text-[10px] text-neutral-400 uppercase tracking-widest"
                >
                    {fechaFormateada}
                </span>
            </div>
        </div>
    </article>

    <!-- Relacionados -->
    {
        relacionados.length > 0 && (
            <section class="py-16 bg-neutral-50 border-t border-neutral-200">
                <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
                    <span class="text-[10px] font-semibold uppercase tracking-[0.2em] text-secondary-600 block mb-6">
                        También te puede interesar
                    </span>

                    <div class="grid md:grid-cols-2 gap-px bg-neutral-200 border border-neutral-200">
                        {relacionados.map((rel) => (
                            <a
                                href={`/noticias/${rel.slug}`}
                                class="bg-white p-6 group relative"
                            >
                                <div class="absolute top-0 left-0 w-0 h-0.5 bg-secondary-500 group-hover:w-full transition-all duration-500" />
                                <div class="flex items-center gap-3 mb-3">
                                    <span class="text-[10px] font-semibold uppercase tracking-widest text-secondary-600">
                                        {rel.categoria}
                                    </span>
                                    <span class="w-1 h-1 bg-neutral-300 rounded-full" />
                                    <span class="text-[11px] text-neutral-400">
                                        {new Date(
                                            rel.fecha + "T12:00:00",
                                        ).toLocaleDateString("es-EC", {
                                            day: "numeric",
                                            month: "short",
                                        })}
                                    </span>
                                </div>
                                <h3 class="text-sm font-bold text-primary-900 group-hover:text-secondary-600 transition-colors leading-snug">
                                    {rel.titulo}
                                </h3>
                                <span class="inline-flex items-center gap-1.5 text-xs font-medium text-primary-700 group-hover:text-secondary-600 transition-colors mt-3 uppercase tracking-wide">
                                    Leer más
                                    <span class="group-hover:translate-x-1 transition-transform">
                                        →
                                    </span>
                                </span>
                            </a>
                        ))}
                    </div>
                </div>
            </section>
        )
    }
</PageLayout>
