---
import PageLayout from "../layouts/PageLayout.astro";
import PageHeader from "../components/common/PageHeader.astro";
import SectionTitle from "../components/common/SectionTitle.astro";
import ActivityCard from "../components/extracurricular/ActivityCard.astro";
import activitiesData from "../data/activities.json";
---

<PageLayout
    title="Actividades Extracurriculares"
    description="Clubes deportivos, academicos y tecnologicos de la Unidad Educativa Jose Acosta Vallejo."
>
    <PageHeader
        title="Actividades Extracurriculares"
        subtitle="Formacion integral mas alla del aula a traves de clubes, deportes y eventos que potencian las habilidades de nuestros estudiantes."
        breadcrumb="Actividades"
    />

    <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <SectionTitle
                title="Clubes Estudiantiles"
                subtitle="Espacios de aprendizaje complementario que fortalecen destrezas y valores"
            />
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {
                    activitiesData.clubes.map((club) => (
                        <ActivityCard
                            nombre={club.nombre}
                            categoria={club.categoria}
                            descripcion={club.descripcion}
                            horario={club.horario}
                            responsable={club.responsable}
                            dirigido={club.dirigido}
                        />
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-20 bg-neutral-50">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
            <SectionTitle
                title="Eventos y Actividades"
                subtitle="Jornadas especiales que enriquecen la experiencia educativa"
            />
            <div class="space-y-px border border-neutral-200">
                {
                    activitiesData.actividades.map((actividad, index) => (
                        <div
                            class:list={[
                                "flex flex-col md:flex-row md:items-center gap-4 md:gap-8 p-6 group hover:bg-primary-50/50 transition-colors relative",
                                index % 2 === 0
                                    ? "bg-white"
                                    : "bg-neutral-50/50",
                            ]}
                        >
                            <div class="absolute top-0 left-0 w-0 h-full border-l-2 border-transparent group-hover:border-secondary-500 transition-all duration-300" />
                            <div class="flex-shrink-0 md:w-32 text-left md:text-right">
                                <span class="text-sm font-bold text-primary-800">
                                    {actividad.fecha}
                                </span>
                                <p class="text-[10px] font-semibold uppercase tracking-widest text-secondary-600 mt-0.5">
                                    {actividad.tipo}
                                </p>
                            </div>
                            <div class="hidden md:block w-px h-12 bg-neutral-200" />
                            <div class="flex-1">
                                <h3 class="text-sm font-bold text-primary-900 uppercase tracking-wide">
                                    {actividad.nombre}
                                </h3>
                                <p class="text-sm text-neutral-500 mt-1.5 leading-relaxed">
                                    {actividad.descripcion}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <section class="py-20 bg-primary-950 relative overflow-hidden">
        <div
            class="absolute inset-0"
            style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px;"
        >
        </div>
        <div
            class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-secondary-400/20 to-transparent"
        >
        </div>
        <div class="relative z-10 max-w-2xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold text-white tracking-tight">
                Quieres inscribir a tu hijo en un club?
            </h2>
            <p class="text-neutral-400 mt-4 leading-relaxed">
                Acercate a secretaria o contacta al docente responsable para mas
                informacion sobre inscripciones en clubes.
            </p>
            <a
                href="/contacto"
                class="inline-flex items-center gap-2 mt-8 text-sm font-medium text-secondary-400 hover:text-secondary-300 transition-colors uppercase tracking-wide group"
            >
                Contactanos
                <span class="group-hover:translate-x-1 transition-transform"
                    >-></span
                >
            </a>
        </div>
    </section>
</PageLayout>
