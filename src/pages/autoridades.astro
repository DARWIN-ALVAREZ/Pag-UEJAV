---
import PageLayout from "../layouts/PageLayout.astro";
import PageHeader from "../components/common/PageHeader.astro";
import DirectiveCard from "../components/staff/DirectiveCard.astro";
import TeacherGrid from "../components/staff/TeacherGrid.astro";
import AdminStaff from "../components/staff/AdminStaff.astro";
import staffData from "../data/staff.json";
---

<PageLayout
    title="Autoridades y Personal"
    description="Conoce al equipo directivo, cuerpo docente y personal administrativo de la Unidad Educativa José Acosta Vallejo."
>
    <PageHeader
        title="Autoridades y Personal"
        subtitle="El equipo humano que hace posible nuestra labor educativa día a día."
        breadcrumb="Autoridades"
    />

    <!-- Consejo Ejecutivo -->
    <section class="py-20 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-14">
                <span
                    class="text-[11px] font-semibold uppercase tracking-[0.2em] text-secondary-600 mb-3 block"
                >
                    Liderazgo
                </span>
                <h2
                    class="text-3xl md:text-4xl font-bold text-primary-900 tracking-tight"
                >
                    Consejo Ejecutivo
                </h2>
                <div class="w-12 h-0.5 bg-secondary-500 mt-5 mx-auto"></div>
            </div>

            <!-- Directora destacada -->
            <div class="max-w-sm mx-auto mb-10">
                <DirectiveCard
                    name={staffData.executives[0].name}
                    role={staffData.executives[0].role}
                    description={staffData.executives[0].description}
                    image={staffData.executives[0].image}
                />
            </div>

            <!-- Subdirector e Inspectora -->
            <div
                class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-neutral-200 border border-neutral-200 max-w-2xl mx-auto mb-10"
            >
                {
                    staffData.executives.slice(1, 3).map((exec) => (
                        <div class="bg-white">
                            <DirectiveCard
                                name={exec.name}
                                role={exec.role}
                                description={exec.description}
                                image={exec.image}
                            />
                        </div>
                    ))
                }
            </div>

            <!-- Vocales -->
            <div
                class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-neutral-200 border border-neutral-200 max-w-4xl mx-auto"
            >
                {
                    staffData.executives.slice(3).map((exec) => (
                        <div class="bg-white">
                            <DirectiveCard
                                name={exec.name}
                                role={exec.role}
                                description={exec.description}
                                image={exec.image}
                            />
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <TeacherGrid
        teachers={staffData.teachers}
        specialTeachers={staffData.specialTeachers}
    />

    <AdminStaff staff={staffData.administrative} />

    <!-- CTA -->
    <section class="py-20 bg-primary-950 relative overflow-hidden">
        <div
            class="absolute inset-0"
            style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px;"
        >
        </div>
        <div
            class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-secondary-400/20 to-transparent"
        >
        </div>

        <div class="relative z-10 max-w-2xl mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold text-white tracking-tight">
                ¿Quieres formar parte de nuestra comunidad?
            </h2>
            <p class="text-neutral-400 mt-4 leading-relaxed">
                Conoce nuestra oferta académica y el proceso de admisión para el
                próximo período lectivo.
            </p>
            <a
                href="/oferta-academica"
                class="inline-flex items-center gap-2 mt-8 text-sm font-medium text-secondary-400 hover:text-secondary-300 transition-colors uppercase tracking-wide group"
            >
                Ver oferta académica
                <span class="group-hover:translate-x-1 transition-transform"
                    >→</span
                >
            </a>
        </div>
    </section>
</PageLayout>
