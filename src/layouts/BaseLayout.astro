---
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
}

const {
	title = "U.E. José Acosta Vallejo",
	description = "Unidad Educativa José Acosta Vallejo - Cangahua, Cayambe. Educación y Cultura desde 1925.",
	ogImage = "/images/logo/logo.png",
} = Astro.props;

const siteName = "U.E. José Acosta Vallejo";
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />

		<!-- SEO -->
		<title>{fullTitle}</title>
		<meta name="description" content={description} />
		<meta name="author" content="U.E. José Acosta Vallejo" />

		<!-- Open Graph -->
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:type" content="website" />
		<meta property="og:locale" content="es_EC" />

		<!-- Favicon -->
		<link rel="icon" type="image/png" href="/images/logo/logo.png" />

		<meta name="generator" content={Astro.generator} />
	</head>
	<body>
		<slot />
	</body>
</html>
