---
import Button from "../common/Button.astro";
---

<section class="relative min-h-[90vh] flex items-center overflow-hidden">
    <!-- Background -->
    <div class="absolute inset-0 bg-primary-950">
        <div
            class="absolute inset-0 bg-gradient-to-b from-primary-900/50 to-primary-950"
        >
        </div>
        <!-- Línea decorativa sutil -->
        <div
            class="absolute inset-0"
            style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 80px 80px;"
        >
        </div>
        <!-- Acento de luz -->
        <div
            class="absolute top-1/4 -right-32 w-[500px] h-[500px] bg-secondary-600/8 rounded-full blur-3xl"
        >
        </div>
    </div>

    <!-- Contenido -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            <!-- Texto -->
            <div class="text-center lg:text-left">
                <div
                    class="inline-flex items-center gap-2 border border-white/10 px-4 py-2 text-secondary-300 text-sm mb-8 tracking-wide uppercase"
                >
                    <span class="w-1.5 h-1.5 bg-secondary-400 rounded-full"
                    ></span>
                    Desde 1925
                </div>

                <h1
                    class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-[1.1] tracking-tight"
                >
                    Unidad Educativa
                    <span class="block text-secondary-300 mt-3"
                        >José Acosta Vallejo</span
                    >
                </h1>

                <div class="w-16 h-0.5 bg-secondary-400 mb-6 mx-auto lg:mx-0">
                </div>

                <p
                    class="text-base text-neutral-400 mb-10 max-w-lg mx-auto lg:mx-0 leading-relaxed"
                >
                    Institución pionera en Cangahua formando estudiantes con
                    agilidad mental, dedicación al estudio y vocación de
                    servicio a la comunidad.
                </p>

                <div
                    class="flex gap-4 justify-center lg:justify-start flex-wrap"
                >
                    <Button href="/admisiones" variant="secondary" size="lg">
                        Inscripciones Abiertas
                    </Button>
                    <Button href="/institucion" variant="outline" size="lg">
                        Conocer más
                    </Button>
                </div>

                <!-- Stats en línea -->
                <div class="flex gap-10 mt-12 justify-center lg:justify-start">
                    <div>
                        <p class="text-3xl font-bold text-white tracking-tight">
                            100
                        </p>
                        <p
                            class="text-xs text-neutral-500 uppercase tracking-widest mt-1"
                        >
                            Años
                        </p>
                    </div>
                    <div class="w-px bg-white/10"></div>
                    <div>
                        <p class="text-3xl font-bold text-white tracking-tight">
                            680+
                        </p>
                        <p
                            class="text-xs text-neutral-500 uppercase tracking-widest mt-1"
                        >
                            Estudiantes
                        </p>
                    </div>
                    <div class="w-px bg-white/10"></div>
                    <div>
                        <p class="text-3xl font-bold text-white tracking-tight">
                            27
                        </p>
                        <p
                            class="text-xs text-neutral-500 uppercase tracking-widest mt-1"
                        >
                            Docentes
                        </p>
                    </div>
                </div>
            </div>

            <!-- Escudo -->
            <div class="hidden lg:flex justify-center">
                <div class="relative">
                    <div
                        class="absolute inset-0 bg-white/20 blur-3xl rounded-full scale-110"
                    >
                    </div>
                    <div
                        class="relative border border-white/20 p-12 rounded-2xl backdrop-blur-md shadow-2xl shadow-white/10"
                        style="background: linear-gradient(145deg, rgba(255,255,255,0.95), rgba(240,240,245,0.88));"
                    >
                        <img
                            src="/images/logo/logo.png"
                            alt="Escudo U.E. José Acosta Vallejo"
                            class="w-72 h-auto drop-shadow-lg"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Línea inferior -->
    <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-secondary-400/30 to-transparent"
    >
    </div>
</section>
