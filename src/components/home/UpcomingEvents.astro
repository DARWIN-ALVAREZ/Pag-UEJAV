---
import SectionTitle from "../common/SectionTitle.astro";
import Button from "../common/Button.astro";

// Datos estáticos por ahora — después vendrán de Google Calendar API
const events = [
    {
        title: "Inicio del Segundo Quimestre",
        date: "2026-03-10",
        time: "07:00",
        location: "Institución",
        type: "academic",
    },
    {
        title: "Reunión de Padres de Familia",
        date: "2026-03-15",
        time: "14:00",
        location: "Salón de Actos",
        type: "meeting",
    },
    {
        title: "Casa Abierta — Proyectos Estudiantiles",
        date: "2026-03-22",
        time: "09:00",
        location: "Patio Principal",
        type: "event",
    },
    {
        title: "Campeonato Intercolegial de Fútbol",
        date: "2026-04-05",
        time: "08:00",
        location: "Cancha Deportiva",
        type: "sports",
    },
];

const typeLabels: Record<string, string> = {
    academic: "Académico",
    meeting: "Reunión",
    event: "Evento",
    sports: "Deportes",
};

const formatDate = (dateStr: string) => {
    const date = new Date(dateStr + "T00:00:00");
    return {
        day: date.toLocaleDateString("es-EC", { day: "2-digit" }),
        month: date
            .toLocaleDateString("es-EC", { month: "short" })
            .toUpperCase()
            .replace(".", ""),
    };
};
---

<section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <SectionTitle
            title="Próximos Eventos"
            subtitle="Mantente al día con las actividades de nuestra institución"
        />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl mx-auto">
            {
                events.map((event) => {
                    const date = formatDate(event.date);
                    return (
                        <div class="flex gap-5 p-5 border border-neutral-200 hover:border-primary-200 transition-all duration-300 group bg-white">
                            {/* Fecha */}
                            <div class="flex-shrink-0 w-16 text-center">
                                <div class="bg-primary-900 text-white px-2 py-1">
                                    <span class="text-[10px] font-semibold uppercase tracking-wider">
                                        {date.month}
                                    </span>
                                </div>
                                <div class="border border-t-0 border-neutral-200 px-2 py-2">
                                    <span class="text-2xl font-bold text-primary-800">
                                        {date.day}
                                    </span>
                                </div>
                            </div>

                            {/* Info */}
                            <div class="flex-1 min-w-0">
                                <span class="text-[10px] font-semibold uppercase tracking-widest text-secondary-600">
                                    {typeLabels[event.type]}
                                </span>
                                <h3 class="font-semibold text-neutral-800 group-hover:text-primary-700 transition-colors mt-1 text-[15px] leading-snug">
                                    {event.title}
                                </h3>
                                <div class="flex items-center gap-4 mt-2.5 text-xs text-neutral-400">
                                    <span class="flex items-center gap-1.5">
                                        <svg
                                            class="w-3.5 h-3.5"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                                            />
                                        </svg>
                                        {event.time}
                                    </span>
                                    <span class="flex items-center gap-1.5">
                                        <svg
                                            class="w-3.5 h-3.5"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                                            />
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                                            />
                                        </svg>
                                        {event.location}
                                    </span>
                                </div>
                            </div>
                        </div>
                    );
                })
            }
        </div>

        <div class="text-center mt-10">
            <a
                href="/eventos"
                class="inline-flex items-center gap-2 text-sm font-medium text-primary-700 hover:text-primary-900 transition-colors uppercase tracking-wide group"
            >
                Ver calendario completo
                <span class="group-hover:translate-x-1 transition-transform"
                    >→</span
                >
            </a>
        </div>
    </div>
</section>
