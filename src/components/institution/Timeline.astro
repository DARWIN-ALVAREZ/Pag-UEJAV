---
const timelineEvents = [
    {
        year: "1925",
        title: "Fundación",
        denomination: "Esc. Fis. de Niños Nº 105",
        description:
            "Se funda la escuela en la parroquia de Cangahua, marcando el inicio de casi un siglo de vocación educativa.",
    },
    {
        year: "1930",
        title: "Primera Denominación",
        denomination: 'Esc. Fis. de Niños "Abdón Calderón"',
        description:
            "La escuela adopta el nombre del héroe niño de la independencia ecuatoriana.",
    },
    {
        year: "1939",
        title: "Segunda Denominación",
        denomination: 'Esc. Fis. de Niños "El Dorado"',
        description: "Nueva etapa institucional con cambio de denominación.",
    },
    {
        year: "1948",
        title: "Homenaje al Patrono",
        denomination: 'Esc. Fis. de Niños "José Acosta Vallejo"',
        description:
            "La institución adopta el nombre del ilustre educador cangahuense José Acosta Vallejo, reconociendo su legado en la formación de generaciones.",
    },
    {
        year: "1953",
        title: "Educación Mixta",
        denomination: 'Esc. Fis. Mixta "José Acosta Vallejo"',
        description:
            "La escuela abre sus puertas a niñas, convirtiéndose en una institución de educación mixta.",
    },
    {
        year: "1996",
        title: "Unidad Educativa",
        denomination: 'Unidad Educativa "José Acosta Vallejo"',
        description:
            "Se eleva a Unidad Educativa, ampliando su oferta académica y consolidándose como referente educativo en Cangahua.",
    },
    {
        year: "2025",
        title: "Un Siglo de Historia",
        denomination: "100 Años de Excelencia",
        description:
            "La institución celebra un siglo de trayectoria ininterrumpida formando estudiantes con agilidad mental, dedicación al estudio y vocación de servicio.",
    },
];
---

<section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <span
                class="text-[11px] font-semibold uppercase tracking-[0.2em] text-secondary-600 mb-3 block"
            >
                1925 — 2025
            </span>
            <h2
                class="text-3xl md:text-4xl font-bold text-primary-900 tracking-tight"
            >
                Nuestra Historia
            </h2>
            <div class="w-12 h-0.5 bg-secondary-500 mt-5 mx-auto"></div>
        </div>

        <!-- Timeline -->
        <div class="relative">
            <!-- Línea central -->
            <div
                class="absolute left-6 md:left-1/2 top-0 bottom-0 w-px bg-neutral-200 md:-translate-x-px"
            >
            </div>

            {
                timelineEvents.map((event, index) => {
                    const isLeft = index % 2 === 0;
                    return (
                        <div
                            class="timeline-item relative mb-12 last:mb-0 opacity-0 translate-y-8"
                            style={`transition-delay: ${index * 100}ms;`}
                        >
                            {/* Punto central */}
                            <div class="absolute left-6 md:left-1/2 w-3 h-3 bg-primary-800 border-2 border-white -translate-x-1.5 mt-1.5 z-10 ring-4 ring-primary-50" />

                            {/* Mobile layout */}
                            <div class="md:hidden pl-14">
                                <span class="text-sm font-bold text-primary-800 tracking-wider">
                                    {event.year}
                                </span>
                                <h3 class="text-lg font-bold text-primary-900 mt-1">
                                    {event.title}
                                </h3>
                                <p class="text-xs font-semibold uppercase tracking-widest text-secondary-600 mt-2">
                                    {event.denomination}
                                </p>
                                <p class="text-sm text-neutral-500 mt-2 leading-relaxed">
                                    {event.description}
                                </p>
                            </div>

                            {/* Desktop layout - alternado */}
                            {isLeft ? (
                                <div class="hidden md:grid md:grid-cols-[1fr_1fr]">
                                    <div class="text-right pr-10">
                                        <span class="text-sm font-bold text-primary-800 tracking-wider">
                                            {event.year}
                                        </span>
                                        <h3 class="text-lg font-bold text-primary-900 mt-1">
                                            {event.title}
                                        </h3>
                                        <p class="text-xs font-semibold uppercase tracking-widest text-secondary-600 mt-2">
                                            {event.denomination}
                                        </p>
                                        <p class="text-sm text-neutral-500 mt-2 leading-relaxed">
                                            {event.description}
                                        </p>
                                    </div>
                                    <div />
                                </div>
                            ) : (
                                <div class="hidden md:grid md:grid-cols-[1fr_1fr]">
                                    <div />
                                    <div class="pl-10">
                                        <span class="text-sm font-bold text-primary-800 tracking-wider">
                                            {event.year}
                                        </span>
                                        <h3 class="text-lg font-bold text-primary-900 mt-1">
                                            {event.title}
                                        </h3>
                                        <p class="text-xs font-semibold uppercase tracking-widest text-secondary-600 mt-2">
                                            {event.denomination}
                                        </p>
                                        <p class="text-sm text-neutral-500 mt-2 leading-relaxed">
                                            {event.description}
                                        </p>
                                    </div>
                                </div>
                            )}
                        </div>
                    );
                })
            }
        </div>
    </div>
</section>

<script>
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target.classList.remove("opacity-0", "translate-y-8");
                    entry.target.classList.add("opacity-100", "translate-y-0");
                    observer.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.2 },
    );

    document.querySelectorAll(".timeline-item").forEach((item) => {
        (item as HTMLElement).style.transition =
            "opacity 0.6s ease, transform 0.6s ease";
        observer.observe(item);
    });
</script>
