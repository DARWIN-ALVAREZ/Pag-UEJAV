---
interface Teacher {
    grade: string;
    section: string;
    name: string;
}

interface SpecialTeacher {
    area: string;
    name: string;
}

interface Props {
    teachers: Teacher[];
    specialTeachers: SpecialTeacher[];
}

const { teachers, specialTeachers } = Astro.props;
---

<section class="py-20 bg-neutral-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
            <span
                class="text-[11px] font-semibold uppercase tracking-[0.2em] text-secondary-600 mb-3 block"
            >
                Cuerpo Docente
            </span>
            <h2
                class="text-3xl md:text-4xl font-bold text-primary-900 tracking-tight"
            >
                Personal Docente
            </h2>
            <div class="w-12 h-0.5 bg-secondary-500 mt-5 mx-auto"></div>
        </div>

        <!-- Tabla de docentes por grado -->
        <div class="border border-neutral-200 bg-white overflow-hidden">
            <!-- Header -->
            <div
                class="grid grid-cols-[1fr_80px_1fr] md:grid-cols-[1fr_100px_1fr] bg-primary-950 text-white"
            >
                <div class="px-5 py-3">
                    <span
                        class="text-[10px] font-semibold uppercase tracking-widest"
                        >Grado / Curso</span
                    >
                </div>
                <div class="px-5 py-3 text-center">
                    <span
                        class="text-[10px] font-semibold uppercase tracking-widest"
                        >Paralelo</span
                    >
                </div>
                <div class="px-5 py-3">
                    <span
                        class="text-[10px] font-semibold uppercase tracking-widest"
                        >Docente</span
                    >
                </div>
            </div>

            <!-- Rows -->
            {
                teachers.map((teacher, index) => (
                    <div
                        class:list={[
                            "grid grid-cols-[1fr_80px_1fr] md:grid-cols-[1fr_100px_1fr] border-t border-neutral-100 hover:bg-primary-50/30 transition-colors",
                            index % 2 === 0 ? "bg-white" : "bg-neutral-50/50",
                        ]}
                    >
                        <div class="px-5 py-3.5">
                            <span class="text-sm text-primary-900 font-medium">
                                {teacher.grade}
                            </span>
                        </div>
                        <div class="px-5 py-3.5 text-center">
                            <span class="text-sm text-neutral-600 font-medium">
                                {teacher.section}
                            </span>
                        </div>
                        <div class="px-5 py-3.5">
                            <span class="text-sm text-neutral-600">
                                {teacher.name}
                            </span>
                        </div>
                    </div>
                ))
            }
        </div>

        <!-- Docentes especializados -->
        <div class="mt-8 border border-neutral-200 bg-white overflow-hidden">
            <div class="grid grid-cols-[1fr_1fr] bg-primary-950 text-white">
                <div class="px-5 py-3">
                    <span
                        class="text-[10px] font-semibold uppercase tracking-widest"
                        >Área</span
                    >
                </div>
                <div class="px-5 py-3">
                    <span
                        class="text-[10px] font-semibold uppercase tracking-widest"
                        >Docente</span
                    >
                </div>
            </div>

            {
                specialTeachers.map((teacher, index) => (
                    <div
                        class:list={[
                            "grid grid-cols-[1fr_1fr] border-t border-neutral-100 hover:bg-primary-50/30 transition-colors",
                            index % 2 === 0 ? "bg-white" : "bg-neutral-50/50",
                        ]}
                    >
                        <div class="px-5 py-3.5">
                            <span class="text-sm text-primary-900 font-medium">
                                {teacher.area}
                            </span>
                        </div>
                        <div class="px-5 py-3.5">
                            <span class="text-sm text-neutral-600">
                                {teacher.name}
                            </span>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
