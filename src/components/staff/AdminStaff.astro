---
interface StaffMember {
    role: string;
    name: string;
}

interface Props {
    staff: StaffMember[];
}

const { staff } = Astro.props;
---

<section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
            <span
                class="text-[11px] font-semibold uppercase tracking-[0.2em] text-secondary-600 mb-3 block"
            >
                Equipo de Apoyo
            </span>
            <h2
                class="text-3xl md:text-4xl font-bold text-primary-900 tracking-tight"
            >
                Personal Administrativo
            </h2>
            <div class="w-12 h-0.5 bg-secondary-500 mt-5 mx-auto"></div>
        </div>

        <div
            class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-neutral-200 border border-neutral-200 max-w-lg mx-auto"
        >
            {
                staff.map((member) => (
                    <div class="bg-white p-6 text-center">
                        <div class="w-16 h-16 bg-primary-50 flex items-center justify-center mx-auto mb-4">
                            <span class="text-2xl opacity-50">👤</span>
                        </div>
                        <span class="text-[10px] font-semibold uppercase tracking-[0.2em] text-secondary-600 block mb-1">
                            {member.role}
                        </span>
                        <p class="text-sm font-medium text-primary-900">
                            {member.name}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
