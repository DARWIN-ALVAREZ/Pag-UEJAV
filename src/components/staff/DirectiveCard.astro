---
interface Props {
    name: string;
    role: string;
    description: string;
}

const { name, role, description } = Astro.props;
---

<div class="bg-white border border-neutral-200 group">
    <div
        class="absolute top-0 left-0 w-0 h-0.5 bg-secondary-500 group-hover:w-full transition-all duration-500 relative"
    >
    </div>

    <!-- Foto placeholder -->
    <div
        class="aspect-[4/3] bg-gradient-to-br from-primary-900 to-primary-800 flex items-center justify-center relative overflow-hidden"
    >
        <div
            class="absolute inset-0"
            style="background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px); background-size: 20px 20px;"
        >
        </div>
        <div class="relative text-center">
            <span class="text-4xl opacity-30">👤</span>
        </div>
    </div>

    <div class="p-6">
        <span
            class="text-[10px] font-semibold uppercase tracking-[0.2em] text-secondary-600 block mb-2"
        >
            {role}
        </span>
        <h3 class="text-lg font-bold text-primary-900 tracking-tight">
            {name}
        </h3>
        <p class="text-sm text-neutral-500 mt-2 leading-relaxed">
            {description}
        </p>
    </div>
</div>
