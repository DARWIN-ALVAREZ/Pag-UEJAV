---
interface Props {
    nombre: string;
    categoria: string;
    descripcion: string;
    horario: string;
    responsable: string;
    dirigido: string;
}

const { nombre, categoria, descripcion, horario, responsable, dirigido } =
    Astro.props;
---

<div class="border border-neutral-200 bg-white group relative">
    <div
        class="absolute top-0 left-0 w-0 h-0.5 bg-secondary-500 group-hover:w-full transition-all duration-500"
    >
    </div>

    <div class="p-6">
        <div class="flex items-start justify-between mb-4">
            <div>
                <span
                    class="text-[10px] font-semibold uppercase tracking-[0.2em] text-secondary-600 block mb-2"
                >
                    {categoria}
                </span>
                <h3 class="text-base font-bold text-primary-900">{nombre}</h3>
            </div>
            <span
                class="text-xs font-medium text-primary-800 bg-primary-50 border border-primary-100 px-2.5 py-1 flex-shrink-0 ml-4"
            >
                {dirigido}
            </span>
        </div>

        <p class="text-sm text-neutral-500 leading-relaxed mb-5">
            {descripcion}
        </p>

        <div class="w-full h-px bg-neutral-100 mb-4"></div>

        <div class="flex items-center justify-between text-xs text-neutral-400">
            <div class="flex items-center gap-1.5">
                <svg
                    class="w-3.5 h-3.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>{horario}</span>
            </div>
            <div class="flex items-center gap-1.5">
                <svg
                    class="w-3.5 h-3.5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                    ></path>
                </svg>
                <span>{responsable}</span>
            </div>
        </div>
    </div>
</div>
