---
interface Props {
    href?: string;
    variant?: "primary" | "secondary" | "outline";
    size?: "sm" | "md" | "lg";
    class?: string;
}

const {
    href,
    variant = "primary",
    size = "md",
    class: className = "",
} = Astro.props;

const baseStyles =
    "inline-flex items-center justify-center font-medium rounded-lg transition-all duration-200";

const variants = {
    primary:
        "bg-primary-700 text-white hover:bg-primary-800 shadow-sm hover:shadow",
    secondary:
        "bg-secondary-500 text-white hover:bg-secondary-600 shadow-sm hover:shadow",
    outline: "border-2 border-primary-700 text-primary-700 hover:bg-primary-50",
};

const sizes = {
    sm: "px-4 py-2 text-sm",
    md: "px-6 py-2.5 text-base",
    lg: "px-8 py-3 text-lg",
};

const Element = href ? "a" : "button";
---

<Element
    href={href}
    class={`${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`}
>
    <slot />
</Element>
