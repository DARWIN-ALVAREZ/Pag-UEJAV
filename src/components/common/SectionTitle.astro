---
interface Props {
    title: string;
    subtitle?: string;
    centered?: boolean;
}

const { title, subtitle, centered = true } = Astro.props;
---

<div class:list={["mb-14", centered && "text-center"]}>
    <h2
        class="text-3xl md:text-4xl font-bold text-primary-900 mb-3 tracking-tight"
    >
        {title}
    </h2>
    {
        subtitle && (
            <p
                class="text-neutral-400 text-base max-w-xl"
                class:list={[centered && "mx-auto"]}
            >
                {subtitle}
            </p>
        )
    }
    <div
        class:list={["w-12 h-0.5 bg-secondary-500 mt-5", centered && "mx-auto"]}
    >
    </div>
</div>
