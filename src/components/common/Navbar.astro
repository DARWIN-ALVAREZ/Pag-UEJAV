---
import { getGuardiania } from "../../services/googleSheets";

const currentPath = Astro.url.pathname;
const guardiania = await getGuardiania();

const navLinks = [
    { name: "Inicio", href: "/" },
    { name: "Institución", href: "/institucion" },
    { name: "Autoridades", href: "/autoridades" },
    { name: "Oferta Académica", href: "/oferta-academica" },
    { name: "Actividades", href: "/actividades" },
    { name: "Cuadro de Honor", href: "/cuadro-honor" },
    { name: "Contacto", href: "/contacto" },
];
---

<header class="bg-white shadow-sm sticky top-0 z-50">
    <!-- Banner Guardiana -->
    <div
        class="bg-primary-800 text-white text-center py-2 text-sm flex items-center justify-center gap-1.5"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"></path><path
                d="M10.3 21a1.94 1.94 0 0 0 3.4 0"></path></svg
        >
        {
            guardiania.current ? (
                <span>
                    Guardiana esta semana:{" "}
                    <strong>{guardiania.current.grade}</strong>
                    {guardiania.next && (
                        <span class="hidden sm:inline">
                            — Próxima: {guardiania.next.grade}
                        </span>
                    )}
                </span>
            ) : (
                <span>Más info en secretaría</span>
            )
        }
    </div>

    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-3">
                <img
                    src="/images/logo/logo.png"
                    alt="Escudo U.E. José Acosta Vallejo"
                    class="h-10 w-auto"
                />
                <div class="hidden sm:block">
                    <p class="text-primary-800 font-bold text-sm leading-tight">
                        U.E. José Acosta Vallejo
                    </p>
                    <p class="text-neutral-500 text-xs">Cangahua - Cayambe</p>
                </div>
            </a>

            <!-- Nav Desktop -->
            <div class="hidden lg:flex items-center gap-1">
                {
                    navLinks.map((link) => (
                        <a
                            href={link.href}
                            class:list={[
                                "px-3 py-2 rounded-md text-sm font-medium transition-colors",
                                currentPath === link.href
                                    ? "bg-primary-50 text-primary-700"
                                    : "text-neutral-600 hover:bg-neutral-50 hover:text-primary-600",
                            ]}
                        >
                            {link.name}
                        </a>
                    ))
                }
            </div>

            <!-- Botón Mobile -->
            <button
                id="menu-toggle"
                class="lg:hidden p-2 rounded-md text-neutral-600 hover:bg-neutral-100"
                aria-label="Abrir menú"
            >
                <svg
                    id="icon-open"
                    class="w-6 h-6"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
                <svg
                    id="icon-close"
                    class="w-6 h-6 hidden"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <!-- Nav Mobile -->
        <div id="mobile-menu" class="hidden lg:hidden pb-4">
            <div class="flex flex-col gap-1">
                {
                    navLinks.map((link) => (
                        <a
                            href={link.href}
                            class:list={[
                                "px-3 py-2 rounded-md text-sm font-medium transition-colors",
                                currentPath === link.href
                                    ? "bg-primary-50 text-primary-700"
                                    : "text-neutral-600 hover:bg-neutral-50 hover:text-primary-600",
                            ]}
                        >
                            {link.name}
                        </a>
                    ))
                }
            </div>
        </div>
    </nav>
</header>

<script>
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("icon-open");
    const iconClose = document.getElementById("icon-close");

    toggle?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
        iconOpen?.classList.toggle("hidden");
        iconClose?.classList.toggle("hidden");
    });
</script>
