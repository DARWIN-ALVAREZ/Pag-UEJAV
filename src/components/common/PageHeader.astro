---
interface Props {
    title: string;
    subtitle?: string;
    breadcrumb?: string;
}

const { title, subtitle, breadcrumb } = Astro.props;
---

<section class="relative bg-primary-950 py-20 overflow-hidden">
    <!-- Grid sutil -->
    <div
        class="absolute inset-0"
        style="background-image: linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px); background-size: 60px 60px;"
    >
    </div>
    <div
        class="absolute top-0 right-0 w-96 h-96 bg-secondary-500/5 rounded-full blur-3xl translate-x-1/3 -translate-y-1/3"
    >
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {
            breadcrumb && (
                <div class="flex items-center gap-2 text-xs text-neutral-500 uppercase tracking-widest mb-6">
                    <a
                        href="/"
                        class="hover:text-secondary-400 transition-colors"
                    >
                        Inicio
                    </a>
                    <span>—</span>
                    <span class="text-secondary-400">{breadcrumb}</span>
                </div>
            )
        }

        <h1 class="text-3xl md:text-5xl font-bold text-white tracking-tight">
            {title}
        </h1>

        {
            subtitle && (
                <p class="text-neutral-400 text-base md:text-lg mt-4 max-w-2xl leading-relaxed">
                    {subtitle}
                </p>
            )
        }

        <div class="w-12 h-0.5 bg-secondary-500 mt-6"></div>
    </div>

    <div
        class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-secondary-400/20 to-transparent"
    >
    </div>
</section>
