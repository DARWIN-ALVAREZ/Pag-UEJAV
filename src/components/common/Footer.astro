---
const currentYear = new Date().getFullYear();

const quickLinks = [
    { name: "Institución", href: "/institucion" },
    { name: "Oferta Académica", href: "/oferta-academica" },
    { name: "Admisiones", href: "/admisiones" },
    { name: "Eventos", href: "/eventos" },
    { name: "Blog", href: "/blog" },
    { name: "Contacto", href: "/contacto" },
];
---

<footer class="bg-primary-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- Info de la escuela -->
            <div>
                <div class="flex items-center gap-3 mb-4">
                    <img
                        src="/images/logo/logo.png"
                        alt="Escudo U.E. José Acosta Vallejo"
                        class="h-12 w-auto"
                    />
                    <div>
                        <p class="font-bold text-lg">
                            U.E. José Acosta Vallejo
                        </p>
                        <p class="text-neutral-300 text-sm">
                            Educación y Cultura desde 1925
                        </p>
                    </div>
                </div>
                <p class="text-neutral-400 text-sm leading-relaxed">
                    Institución pionera con educación holística de calidad,
                    formando estudiantes con agilidad mental, dedicación al
                    estudio y vocación de servicio a la comunidad.
                </p>
            </div>

            <!-- Enlaces rápidos -->
            <div>
                <h3 class="text-lg font-semibold mb-4 text-white">
                    Enlaces Rápidos
                </h3>
                <nav class="flex flex-col gap-2">
                    {
                        quickLinks.map((link) => (
                            <a
                                href={link.href}
                                class="text-neutral-400 hover:text-secondary-300 transition-colors text-sm"
                            >
                                {link.name}
                            </a>
                        ))
                    }
                </nav>
            </div>

            <!-- Contacto -->
            <div>
                <h3 class="text-lg font-semibold mb-4 text-white">Contacto</h3>
                <div class="flex flex-col gap-3 text-sm text-neutral-400">
                    <div class="flex items-start gap-2">
                        <span class="text-secondary-300 flex-shrink-0 mt-0.5">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
                                ></path><circle cx="12" cy="10" r="3"
                                ></circle></svg
                            >
                        </span>
                        <span>Juan Montalvo y Quiroga, Cangahua, Cayambe</span>
                    </div>
                    <div class="flex items-start gap-2">
                        <span class="text-secondary-300 flex-shrink-0 mt-0.5">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"
                                ></path></svg
                            >
                        </span>
                        <a
                            href="tel:022363372"
                            class="hover:text-secondary-300 transition-colors"
                        >
                            (02) 236-3372
                        </a>
                    </div>
                    <div class="flex items-start gap-2">
                        <span class="text-secondary-300 flex-shrink-0 mt-0.5">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><rect width="20" height="16" x="2" y="4" rx="2"
                                ></rect><path
                                    d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"
                                ></path></svg
                            >
                        </span>
                        <a
                            href="mailto:jose_acosta_vallejo@hotmail.com"
                            class="hover:text-secondary-300 transition-colors"
                        >
                            jose_acosta_vallejo@hotmail.com
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Línea divisora y copyright -->
        <div class="border-t border-neutral-700 mt-8 pt-8 text-center">
            <p class="text-neutral-500 text-sm">
                &copy; {currentYear} Unidad Educativa José Acosta Vallejo. Todos los
                derechos reservados.
            </p>
            <p class="text-neutral-600 text-xs mt-2">
                Realizado por
                <a
                    href="https://bjesus.link"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-secondary-400 hover:text-secondary-300 transition-colors font-medium"
                >
                    Bryan Jesús Tandayamo Sopalo
                </a>
            </p>
        </div>
    </div>
</footer>
