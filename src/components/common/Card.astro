---
interface Props {
    title?: string;
    image?: string;
    imageAlt?: string;
    class?: string;
}

const { title, image, imageAlt = "", class: className = "" } = Astro.props;
---

<div
    class={`bg-white rounded-xl shadow-sm border border-neutral-200 overflow-hidden hover:shadow-md transition-shadow duration-200 ${className}`}
>
    {
        image && (
            <div class="aspect-video overflow-hidden">
                <img
                    src={image}
                    alt={imageAlt}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                />
            </div>
        )
    }
    <div class="p-5">
        {
            title && (
                <h3 class="text-lg font-semibold text-primary-800 mb-2">
                    {title}
                </h3>
            )
        }
        <slot />
    </div>
</div>
