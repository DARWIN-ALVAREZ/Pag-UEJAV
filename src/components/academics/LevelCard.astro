---
interface Props {
    subnivel: string;
    grados: string;
    edades: string;
    descripcion: string;
    materias: string[];
    index: number;
}

const { subnivel, grados, edades, descripcion, materias, index } = Astro.props;
---

<div class="border border-neutral-200 bg-white group relative">
    <div
        class="absolute top-0 left-0 w-0 h-0.5 bg-secondary-500 group-hover:w-full transition-all duration-500"
    >
    </div>

    <div class="p-8">
        <!-- Header -->
        <div class="flex items-start justify-between mb-6">
            <div>
                <span
                    class="text-[10px] font-semibold uppercase tracking-[0.2em] text-secondary-600 block mb-2"
                >
                    Subnivel {String(index + 1).padStart(2, "0")}
                </span>
                <h3 class="text-xl font-bold text-primary-900">{subnivel}</h3>
            </div>
            <div class="text-right flex-shrink-0 ml-4">
                <p class="text-sm font-semibold text-primary-800">{grados}</p>
                <p class="text-xs text-neutral-400 mt-0.5">{edades}</p>
            </div>
        </div>

        <div class="w-full h-px bg-neutral-100 mb-6"></div>

        <!-- Descripción -->
        <p class="text-sm text-neutral-600 leading-relaxed mb-6">
            {descripcion}
        </p>

        <!-- Materias -->
        <div>
            <span
                class="text-[10px] font-semibold uppercase tracking-[0.2em] text-neutral-400 block mb-3"
            >
                Malla Curricular
            </span>
            <div class="flex flex-wrap gap-2">
                {
                    materias.map((materia) => (
                        <span class="text-xs font-medium text-primary-800 bg-primary-50 border border-primary-100 px-3 py-1.5">
                            {materia}
                        </span>
                    ))
                }
            </div>
        </div>
    </div>
</div>
