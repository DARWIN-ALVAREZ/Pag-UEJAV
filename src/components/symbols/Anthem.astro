---
import AudioPlayer from '../common/AudioPlayer.astro';
---

<section class="py-20 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
            <span
                class="text-[11px] font-semibold uppercase tracking-[0.2em] text-secondary-600 mb-3 block"
            >
                Himno Institucional
            </span>
            <h2
                class="text-3xl md:text-4xl font-bold text-primary-900 tracking-tight"
            >
                Himno a la Institución
            </h2>
            <div class="w-12 h-0.5 bg-secondary-500 mt-5 mx-auto"></div>
        </div>

        <div class="max-w-2xl mx-auto">
            <div class="border border-neutral-200 bg-white">
                <!-- Header -->
                <div class="bg-primary-950 px-8 py-5">
                    <p
                        class="text-secondary-300 text-sm font-medium tracking-wide"
                    >
                        Unidad Educativa "José Acosta Vallejo"
                    </p>
                </div>

                <!-- Estrofas -->
                <div class="p-8 md:p-12 space-y-8">
                    <div class="space-y-1">
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            José Acosta es el Patrono
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            de esta escuela, de este templo.
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            Hombre que dio muchos ejemplo
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            y educar fue su tarea.
                        </p>
                    </div>

                    <div class="w-8 h-px bg-neutral-200 mx-auto"></div>

                    <div class="space-y-1">
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            Tu nombre lleva mi escuela,
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            con orgullo y corazón.
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            Porque en la niñez pusiste
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            todo tu corazón.
                        </p>
                    </div>

                    <div class="w-8 h-px bg-neutral-200 mx-auto"></div>

                    <div class="space-y-1">
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            Tus amigos, tus alumnos
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            te recuerdan siempre, siempre.
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            ¡Oh!, maestro que formaste
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            a muchas generaciones.
                        </p>
                    </div>

                    <div class="w-8 h-px bg-neutral-200 mx-auto"></div>

                    <div class="space-y-1">
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            Tus ejemplos seguiremos
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            quienes estamos aquí,
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            para ser lo que tú fuiste:
                        </p>
                        <p
                            class="text-primary-900 font-serif text-lg leading-relaxed italic"
                        >
                            hombre de lucha y valor.
                        </p>
                    </div>
                </div>

                <!-- Custom Audio Player Extension -->
                <div class="px-8 md:px-12 pb-10">
                    <AudioPlayer src="/audio/himno.mpeg" title="Himno a la Institución" />
                </div>

                <!-- Footer -->
                <div
                    class="border-t border-neutral-200 px-8 py-4 bg-neutral-50"
                >
                    <p
                        class="text-xs text-neutral-400 uppercase tracking-widest text-right"
                    >
                        Letra: Prof. Amílcar Salgado Pérez
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
